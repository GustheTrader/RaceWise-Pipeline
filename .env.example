# Copy to .env.local and fill in real values. .env.local is gitignored.

# --- LLM provider selection -------------------------------------------------
# openrouter (default) | gemini
LLM_PROVIDER=openrouter

# OpenRouter model slug. Examples:
#   google/gemini-2.5-pro        (strong PDF + JSON schema, default)
#   anthropic/claude-sonnet-4.5  (strong reasoning, PDF-capable)
#   openai/gpt-4o                (good multimodal baseline)
#   qwen/qwen-2.5-vl-72b-instruct (open-source multimodal)
# Append ":online" via code for live-web scrape calls.
LLM_MODEL=google/gemini-2.5-pro

# --- Credentials ------------------------------------------------------------
OPENROUTER_API_KEY=
GEMINI_API_KEY=
