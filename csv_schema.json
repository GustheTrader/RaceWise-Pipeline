
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "RaceWise CSV Row Contract",
  "description": "Schema for a single row in the master_stats.csv flattened output stream, including Jockey, Trainer, and the last 5 past performances.",
  "type": "object",
  "properties": {
    "RaceID": {
      "type": "string",
      "description": "Unique identifier for the race (Track_Date_RaceNumber)",
      "pattern": "^[A-Z0-9]{2}_[0-9]{4}_[0-9]{2}$"
    },
    "Horse": {
      "type": "string",
      "description": "The name of the horse"
    },
    "Pg_Num": {
      "type": "string",
      "description": "The program or post position number (e.g., '1', '1A', '12')",
      "pattern": "^[0-9]{1,2}[A-Z]?$"
    },
    "Jockey": {
      "type": "string",
      "description": "The name of the jockey"
    },
    "Trainer": {
      "type": "string",
      "description": "The name of the trainer"
    },
    "FIRE": {
      "type": "integer",
      "description": "FIRE speed rating",
      "minimum": 0,
      "maximum": 150
    },
    "CPR": {
      "type": "integer",
      "description": "Comprehensive Performance Rating",
      "minimum": 0,
      "maximum": 150
    },
    "FastFig": {
      "type": "integer",
      "description": "Calculated Fast Figure",
      "minimum": 0,
      "maximum": 150
    },
    "Consensus": {
      "type": "integer",
      "description": "Total consensus points",
      "minimum": 0,
      "maximum": 99
    },
    "PP1_Date": { "type": "string" },
    "PP1_Finish": { "type": "string" },
    "PP1_Dist": { "type": "string" },
    "PP2_Date": { "type": "string" },
    "PP2_Finish": { "type": "string" },
    "PP2_Dist": { "type": "string" },
    "PP3_Date": { "type": "string" },
    "PP3_Finish": { "type": "string" },
    "PP3_Dist": { "type": "string" },
    "PP4_Date": { "type": "string" },
    "PP4_Finish": { "type": "string" },
    "PP4_Dist": { "type": "string" },
    "PP5_Date": { "type": "string" },
    "PP5_Finish": { "type": "string" },
    "PP5_Dist": { "type": "string" }
  },
  "required": [
    "RaceID", 
    "Horse", 
    "Pg_Num", 
    "FIRE", 
    "CPR", 
    "FastFig", 
    "Consensus"
  ]
}
