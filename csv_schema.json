{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "RaceWise Master Dataset Contract",
  "description": "Schema for the comprehensive master_stats.csv output including ensemble scores and historical performance triplets.",
  "type": "object",
  "properties": {
    "Rank": { "type": "integer" },
    "Track": { "type": "string" },
    "Date": { "type": "string" },
    "RaceNum": { "type": "integer" },
    "Pg_Num": { "type": "string" },
    "Horse": { "type": "string" },
    "ML_Odds": { "type": "string" },
    "Model_Odds": { "type": "string" },
    "Model_Score": { "type": "number" },
    "Win_Prob": { "type": "string" },
    "Jockey_Win_Pct": { "type": "string" },
    "Trainer_Win_Pct": { "type": "string" },
    "HF": { "type": "string" },
    "Comments": { "type": "string" },
    "FIRE": { "type": "integer" },
    "CPR": { "type": "integer" },
    "FastFig": { "type": "integer" },
    "Consensus": { "type": "integer" },
    "PP1_Date": { "type": "string" },
    "PP1_Finish": { "type": "string" },
    "PP1_Dist": { "type": "string" },
    "PP2_Date": { "type": "string" },
    "PP2_Finish": { "type": "string" },
    "PP2_Dist": { "type": "string" },
    "PP3_Date": { "type": "string" },
    "PP3_Finish": { "type": "string" },
    "PP3_Dist": { "type": "string" },
    "PP4_Date": { "type": "string" },
    "PP4_Finish": { "type": "string" },
    "PP4_Dist": { "type": "string" },
    "PP5_Date": { "type": "string" },
    "PP5_Finish": { "type": "string" },
    "PP5_Dist": { "type": "string" }
  },
  "required": ["Rank", "Horse", "Model_Score", "Win_Prob", "ML_Odds"]
}